# -----------------------------------------------------------------------------
# Public portfolio app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://image.sunnygong.com
NEXT_PUBLIC_SITE_NAME=Sunny Gong Images
IMMICH_URL=http://immich-server:2283
IMMICH_API_KEY=replace-with-read-only-immich-api-key
PORTFOLIO_DB_PATH=/app/data/portfolio.sqlite
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
AI_SOURCE_ROOT=/srv/photos/library
AI_EXPORT_ROOT=/srv/photos/portfolio-export
AI_BATCH_STATE_DIR=/app/ops/ai-ranking/state

# -----------------------------------------------------------------------------
# Caddy / reverse proxy (TLS handled by Cloudflare Tunnel)
# -----------------------------------------------------------------------------
# Cloudflare Tunnel routes:
#   image.sunnygong.com  -> http://localhost:8380
#   immich.sunnygong.com -> http://localhost:8280
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BCRYPT_HASH=$2a$14$replace.with.caddy.bcrypt.hash

# -----------------------------------------------------------------------------
# Immich official variables
# -----------------------------------------------------------------------------
UPLOAD_LOCATION=/mnt/nas/immich/uploads
IMMICH_EXTERNAL_LIBRARY_PATH=/mnt/nas/photos/library
DB_DATA_LOCATION=/mnt/nas/immich/postgres
TZ=America/Toronto
IMMICH_VERSION=v2
DB_PASSWORD=changeMeToALongRandomAlphaNumericString
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
